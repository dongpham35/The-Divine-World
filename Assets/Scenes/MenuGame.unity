  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "T\u1ED3n t\u1EA1i m\u1ED9t th\u1EBF gi\u1EDBi ph\u1EE9c t\u1EA1p, \u0111\u01B0\u1EE3c
    chia th\xE0nh b\u1ED1n qu\u1ED1c gia l\u1EDBn \u0111\u01B0\u1EE3c bi\u1EBFt \u0111\u1EBFn
    v\u1EDBi c\xE1c y\u1EBFu t\u1ED1 kh\xED, n\u01B0\u1EDBc, \u0111\u1EA5t, v\xE0
    l\u1EEDa. M\u1ED7i qu\u1ED1c gia \u0111\u1EC1u c\xF3 nh\u1EEFng ng\u01B0\u1EDDi
    c\xF3 kh\u1EA3 n\u0103ng chi ph\u1ED1i v\xE0 k\u1EF9 n\u0103ng \u0111i\u1EC1u
    khi\u1EC3n y\u1EBFu t\u1ED1 t\u01B0\u01A1ng \u1EE9ng.\nNhi\u1EC7m v\u1EE5 c\u1EE7a
    b\u1EA1n l\xE0 n\xE2ng c\u1EA5p s\u1EE9c m\u1EA1nh b\u1EA3n th\xE2n \u0111\u1EC3
    t\u1ED3n t\u1EA1i \u0111\u01B0\u1EE3c trong th\u1EBF gi\u1EDBi n\xE0y.\nB\u1EA1n
    c\xF3 th\u1EC3 trang b\u1ECB nh\u1EEFng v\u0169 kh\xED m\u1EA1nh m\u1EBD ho\u1EB7c
    nh\u1EEFng b\u1ED9 gi\xE1p c\u1EE9ng r\u1EAFn ho\u1EB7c nh\u1EEFng v\u1EADt th\u1EA7n
    k\u1EF3 ch\u1EC9 t\u1ED3n t\u1EA1i trong th\u1EBF gi\u1EDBi n\xE0y\n\u0110\u1EC3
    \u0111i\u1EC1u khi\u1EC3n nh\xE2n v\u1EADt:\n- a,w,d \u0111\u1EC3 di chuy\u1EC3n
    tr\xE1i, nh\u1EA3y, ph\u1EA3i\n- j,k,l \u0111\u1EC3 t\u1EA5n c\xF4ng"
